        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to **Personal Best Running**. These Terms of Service (\"Terms\") govern your use of our application. By downloading, installing, or using Personal Best Running, you agree to be bound by these Terms."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenido a **Personal Best Running**. Estos Términos de Servicio (\"Términos\") regulan tu uso de nuestra aplicación. Al descargar, instalar o usar Personal Best Running, aceptas estar vinculado por estos Términos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenue dans **Personal Best Running**. Ces conditions d'utilisation (« Conditions ») régissent votre utilisation de notre application. En téléchargeant, en installant ou en utilisant Personal Best Running, vous acceptez d'être lié par ces Conditions."
          }
        },
