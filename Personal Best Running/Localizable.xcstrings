    "paces.note.zone1" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zone 1 (Z1) — why it is not in the table"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zona 1 (Z1) — por qué no está en la tabla"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zone 1 (Z1) — parce qu'elle n'est pas dans le tableau"
          }
        },
        "it" : {
