    "workoutDescription.easyRecovery": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Very easy running in the low end of E-pace. Goal: facilitate recovery, not build fitness.\n"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carrera muy fácil en el límite bajo del E-pace. Objetivo: facilitar la recuperación, no construir forma.\n"
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Corsa molto leggera nell'intervallo basso dell'E-pace. Obiettivo: promuovere il recupero, non costruire fitness."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Very easy running in the low end of E-pace. Goal: facilitate recovery, not build fitness.\n"
          }
        }
      }
    },
    "workoutDescription.hillRepeat": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High-intensity hill repeats. Recovery during the slow downhill. Used in the Base phase as a strength-speed stimulus with low joint impact."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Repeticiones en pendiente de alta intensidad. Recuperación en la bajada lenta. Usado en la fase Base como estímulo de fuerza-velocidad con bajo impacto articular."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Collinare ad alta intensità. Recupero in discesa lenta. Usate nella fase Base come stimolo di forza-velocità a basso impatto articolare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "High-intensity hill repeats. Recovery during the slow downhill. Used in the Base phase as a strength-speed stimulus with low joint impact."
          }
        }
      }
    },
    "workoutDescription.interval": {
