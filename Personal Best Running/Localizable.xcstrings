    "workoutDescription.repetition": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short intervals at R-pace (105-120% VDOT). Full recovery between reps: do not start the next one until you are ready to run with good mechanics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Intervalos cortos a R-pace (105-120% VDOT). Recuperación completa entre repeticiones: no empieces la siguiente hasta que estés listo para correr con buena mecánica."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Ripetute brevi a ritmo R (105-120% VDOT). Recupero completo tra le ripetizioni: non iniziare la prossima finché non sei pronto a correre con buona meccanica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Short intervals at R-pace (105-120% VDOT). Full recovery between reps: do not start the next one until you are ready to run with good mechanics."
          }
        }
      }
    },
