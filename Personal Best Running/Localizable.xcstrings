    },
    "paces.note.zone1.body" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daniels does not assign a specific pace to Z1: E-pace (Z2, 59-74% VO2max) already covers the entire low-intensity range, including active recovery. On recovery days, run at the lower end of E-pace without a precise target — the goal is to move, not to train."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Daniels non assegna un ritmo specifico alla Z1: l'E-pace (Z2, 59-74% VO2max) copre già tutto il range di bassa intensità, recupero attivo incluso. Nei giorni di recupero corri al limite inferiore dell'E-pace senza un target preciso — l'obiettivo è muoversi, non allenare."
          }
        }
      }
    },
