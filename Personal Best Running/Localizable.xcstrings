    "paces.note.howCalculated.body": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paces are based on your current VDOT (%@), not on your target. Train at the level you are today: paces improve as VDOT grows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los ritmos se basan en tu VDOT actual (%@), not on your target. Train at the level you are today: paces improve as VDOT grows."
          }
        },
        "it": {
          "stringUnit": {
            "state": "new",
            "value": "Le andature si basano sul tuo VDOT attuale (%@), non sull'obiettivo. Ci si allena alla forma che si ha oggi: i ritmi migliorano man mano che il VDOT cresce."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paces are based on your current VDOT (%@), not on your target. Train at the level you are today: paces improve as VDOT grows."
          }
        }
      }
    },
