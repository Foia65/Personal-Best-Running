    "paces.note.zone1" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zone 1 (Z1) — why it is not in the table"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Zona 1 (Z1) — perché non è in tabella"
