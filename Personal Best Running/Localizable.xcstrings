    "goalFeasibility.raceDescription.realistic" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! Your goal should be aligned with your current form. Execute your race plan: the work you've done supports it. Start cautiously for the first few kilometers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Tu objetivo debería estar alineado con tu forma actual. Ejecuta tu plan de carrera: el trabajo realizado lo respalda. Empieza con cautela en los primeros kilómetros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! Objectif aligné avec votre forme actuelle. Exécuter le plan de course : le travail effectué le soutient. Partez prudemment dans les premiers kilomètres."
          }
