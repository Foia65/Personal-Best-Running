    "goalFeasibility.raceDescription.ambitious" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! Ambitious goal considering your starting form. If the plan goes well, you can do it. It's crucial to start cautiously in the first few kilometers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Objetivo ambicioso considerando tu forma de partida. Si el plan va bien, puedes lograrlo. Es crucial empezar con cautela en los primeros kilómetros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! Objectif ambitieux par rapport à la forme de départ. Si le plan s'est bien déroulé, vous pouvez le faire. Il est essentiel de démarrer prudemment dès les premiers kilomètres."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Giorno di gara! Obiettivo ambizioso rispetto alla forma di partenza. Se il piano è andato bene, puoi farcela. Fondamentale partire cauto nei primi km."
          }
        }
      }
    },
    "goalFeasibility.raceDescription.challenging" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! A very challenging goal considering your starting form. Run at your best and use this race as a warm-up."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Objetivo muy desafiante considerando tu forma de partida. Corre lo mejor que puedas y usa esta carrera como calentamiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! Objectif très ambitieux par rapport à la forme de départ. Courez au mieux de votre condition actuelle et utilisez cette course comme étape d'initiation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Giorno di gara! Obiettivo molto sfidante rispetto alla forma di partenza. Corri al meglio della tua condizione attuale e usa questa gara come tappa di avvicinamento."
          }
        }
      }
    },
    "goalFeasibility.raceDescription.conservative" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! Your goal is very conservative compared to your current form: you could do much better. Start calmly and evaluate whether to increase your pace as you go."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Tu objetivo es muy conservador comparado con tu forma actual: podrías hacer mucho mejor. Empieza con calma y evalúa si aumentar el ritmo según avanzas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! Votre objectif est très conservateur par rapport à la forme actuelle : vous pourriez faire bien mieux. Commencez de manière contrôlée et décidez si vous souhaitez augmenter le rythme pendant que vous courez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Giorno di gara! Il tuo obiettivo è molto conservativo rispetto alla forma attuale: potresti fare molto meglio. Parti controllato e valuta in corsa se aumentare il ritmo."
          }
        }
      }
    },
    "goalFeasibility.raceDescription.extreme" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! Your stated goal was way beyond your starting form. Run at your estimated pace: use this race as experience and reevaluate your goal for the next cycle."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Tu objetivo declarado estaba muy más allá de tu forma de partida. Corre a tu ritmo estimado: usa esta carrera como experiencia y reevalúa tu objetivo para el próximo ciclo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! L'objectif déclaré allait bien au-delà de la forme de départ. Courez à votre rythme estimé : utilisez cette course comme expérience et réévaluez votre objectif pour le prochain cycle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Giorno di gara! L'obiettivo dichiarato era molto oltre la forma di partenza. Corri al tuo ritmo stimato: usa questa gara come esperienza e rivaluta l'obiettivo per il prossimo ciclo."
          }
        }
      }
    },
    "goalFeasibility.raceDescription.prudent" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Race day! A conservative goal given your current form. An excellent foundation for a solid, risk-free result. Run with confidence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Día de carrera! Objetivo conservador dada tu forma actual. Una excelente base para un resultado sólido y sin riesgos. Corre con confianza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jour de course ! Objectif conservateur par rapport à la forme actuelle. Excellente base pour un résultat solide sans risques. Courez en toute confiance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Giorno di gara! Obiettivo prudente rispetto alla forma attuale. Ottima base per un risultato solido senza rischi. Corri con fiducia."
          }
