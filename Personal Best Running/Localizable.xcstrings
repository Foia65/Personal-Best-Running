    "Hai una base aerobica ben sviluppata e tolleri sessioni di qualità. Puoi lavorare su soglia e ritmo maratona con buoni risultati." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have a well-developed aerobic base and can tolerate quality sessions. You can work on threshold and marathon pace with good results."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes una base aeróbica bien desarrollada y toleras bien las sesiones de calidad. Puedes trabajar en ritmo umbral y ritmo maratón con buenos resultados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez une base aérobie bien développée et supportez des séances de qualité. Vous pouvez travailler le seuil et le rythme marathon avec de bons résultats."
          }
        }
      }
    },
