    "methodology.zone.purpose.E" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Base aerobic development, active recovery, muscle-tendon adaptation. ~80% of total weekly volume."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desarrollo aeróbico base, recuperación activa, adaptación músculo-tendinosa. ~80% del volumen semanal total."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Développement aérobie de base, récupération active, adaptation musculo-tendineuse. ~80% du volume hebdomadaire total."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Sviluppo aerobico di base, recupero attivo, adattamento muscolo-tendineo. ~80% del volume settimanale totale."
          }
        }
      }
    },
    "methodology.zone.purpose.I" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximizes time at VO2max. Stimulates cardiac output, capillary density, and mitochondrial density. Max of 10K or 8% of weekly volume, whichever is less."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximiza el tiempo a VO2max. Estimula el gasto cardíaco, densidad capilar y densidad mitocondrial. Máximo 10K o 8% del volumen semanal, lo que sea menor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximisez le temps nécessaire pour atteindre VO2max. Stimule le débit cardiaque, la densité capillaire et la densité mitochondriale. Max 10 km ou 8 % du volume hebdomadaire, selon le montant le moins élevé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Massimizza il tempo a VO2max. Stimola la portata cardiaca, la densità capillare e la densità mitocondriale. Max 10 km o 8% del volume settimanale, il minore dei due."
          }
        }
      }
    },
    "methodology.zone.purpose.M" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specific adaptation to marathon race pace. Optimizes running economy and pace management."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptación específica al ritmo de carrera de maratón. Optimiza la economía de carrera y la gestión del ritmo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaptation spécifique au rythme de la course marathon. Optimisez les économies de course et la gestion du rythme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adattamento specifico al ritmo gara maratona. Ottimizza l'economia di corsa e la gestione del ritmo."
          }
        }
      }
    },
    "methodology.zone.purpose.R" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improves speed, running economy, and anaerobic power. Introduced before I (adds only speed stimulus). Max 5% of weekly volume."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mejora velocidad, economía de carrera y potencia anaeróbica. Introducido antes de I (añade solo estímulo de velocidad). Máx 5% del volumen semanal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Améliore la vitesse, l’économie de fonctionnement et la puissance anaérobie. Introduit avant I (ajoute uniquement un stimulus de vitesse). Max 5% du volume hebdomadaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Migliora velocità, economia di corsa e potenza anaerobica. Introdotto prima di I (aggiunge solo stimolo di velocità). Max 5% del volume settimanale."
          }
        }
      }
    },
    "methodology.zone.purpose.T" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improves anaerobic threshold and lactate clearance capacity. Max 10% of weekly volume per session."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mejora el umbral anaeróbico y capacidad de eliminación de lactato. Máx 10% del volumen semanal por sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Améliore le seuil anaérobie et la capacité de clairance du lactate. Max 10% du volume hebdomadaire par séance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Migliora la soglia anaerobica e la capacità di clearance del lattato. Max 10% del volume settimanale per sessione."
          }
        }
      }
    },
