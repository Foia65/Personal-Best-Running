    "Per domande relative ai presenti Termini, è possibile contattarci a:" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For questions regarding these Terms, you may contact us at:"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para preguntas sobre estos Términos, contáctanos en:"
          }
        },
